# Прокси для сборки Docker-образа (docker compose build / docker build).
# Можно задать здесь или экспортировать в shell перед сборкой.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.local

# Локальная разработка вне Docker (скопируйте в .env)
DATABASE_URL=postgresql+psycopg://very_english:very_english@127.0.0.1:5432/very_english
JWT_SECRET_KEY=dev-jwt-secret-change-me
S3_BUCKET=very-english-media
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://127.0.0.1:9000
# Публичный URL для presigned-ссылок (фронт/браузер). В Docker API — minio:9000, снаружи — localhost:9000.
# AWS_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000
API_HOST=0.0.0.0
API_PORT=8000
# Не задавайте или оставьте пустым — список по умолчанию (localhost + 95.163.244.138)
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://example.com
REDIS_URL=redis://127.0.0.1:6379/0
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Проверка IP webhook ЮKassa (false — только для локальной отладки через туннель)
# YOOKASSA_WEBHOOK_IP_CHECK=true
BILLING_RENEW_INTERVAL_SECONDS=3600
BILLING_SYNC_INTERVAL_SECONDS=300
